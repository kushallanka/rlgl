{
  "permissions": {
    "allow": [
      "Bash(docker exec testcase-service node -e ' *)",
      "PowerShell(docker port rlgl-gateway 2>&1)",
      "PowerShell(docker port rlgl-frontend 2>&1)",
      "PowerShell(docker cp c:\\\\Code\\\\test-management\\\\test-db.mjs testcase-service:/app/test-db.mjs 2>&1)",
      "PowerShell(docker exec testcase-service node /app/test-db.mjs 2>&1)",
      "PowerShell(docker exec testcase-service sh -c 'which sqlite3; ls /app/services/testcase/node_modules/.bin/prisma 2>/dev/null || echo \"no prisma bin\"; ls /app/node_modules/.bin/prisma 2>/dev/null || echo \"no root prisma\"' 2>&1)",
      "PowerShell(docker exec testcase-service sh -c 'find /app -name \"prisma\" -type f 2>/dev/null | head -5; which node' 2>&1)",
      "PowerShell(docker exec testcase-service node --version 2>&1)",
      "PowerShell(docker cp c:\\\\Code\\\\test-management\\\\apply-migration.mjs testcase-service:/app/apply-migration.mjs 2>&1)",
      "PowerShell(docker exec testcase-service node /app/apply-migration.mjs 2>&1)",
      "PowerShell(docker exec testcase-service rm /app/test-db.mjs /app/apply-migration.mjs 2>&1)",
      "PowerShell(docker exec rlgl-gateway wget -qO- \"http://testcase-service:3003/cases\" --header \"x-project-id: 2\" 2>&1)",
      "PowerShell(head -20)"
    ]
  }
}
