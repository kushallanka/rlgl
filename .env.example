NODE_ENV=development
PORT=3000
JWT_SECRET=auth-secret-key-change-in-prod

# Redis (EventBus, Rate Limiting, Sessions)
REDIS_URL=redis://localhost:6379

# Service URLs
AUTH_SERVICE_URL=http://localhost:3001
PROJECT_SERVICE_URL=http://localhost:3002
TESTCASE_SERVICE_URL=http://localhost:3003
TESTRUN_SERVICE_URL=http://localhost:3004

# Database URLs
AUTH_DATABASE_URL="file:./data/auth/auth.db"
PROJECT_DATABASE_URL="file:./data/project/project.db"
TESTCASE_DATABASE_URL="file:./data/testcase/testcase.db"
TESTRUN_DATABASE_URL="file:./data/testrun/testrun.db"

# Gateway Configuration
GATEWAY_HEALTH_PROBE_UPSTREAMS=true
GATEWAY_PROXY_TIMEOUT_MS=30000
GATEWAY_PROXY_CONNECT_TIMEOUT_MS=5000

# Seed Admin Credentials
SEED_ADMIN_EMAIL=admin@test.com
SEED_ADMIN_PASSWORD=AdminPass123!
SEED_ADMIN_NAME="Alice Admin"

# Seed Tester Credentials
SEED_TESTER_EMAIL=tester@test.com
SEED_TESTER_PASSWORD=TesterPass123!
SEED_TESTER_NAME="Bob Tester"

# ─── Observability ───────────────────────────────────────────────────────────

# Grafana Admin Password (default: admin)
GRAFANA_ADMIN_PASSWORD=admin

# Log Level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# Log Sampling Rate (1 = 100%, 0.1 = 10%)
LOG_SAMPLING_RATE=1

# Metrics Enabled
METRICS_ENABLED=true
