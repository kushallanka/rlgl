datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  output        = "../generated/client"
  binaryTargets = ["native", "windows"]
}

model Project {
  id          Int          @id
  name        String       @default("")
  testRuns    TestRun[]
  deletedAt   DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
}

model Suite {
  id          Int          @id @default(autoincrement())
  projectId   Int
  name        String
  testRuns    TestRun[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now())
}

model TestRun {
  id          Int          @id @default(autoincrement())
  projectId   Int
  suiteId     Int?
  name        String
  description String?
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  suite       Suite?       @relation(fields: [suiteId], references: [id], onDelete: SetNull)
  createdBy   String?
  deletedAt   DateTime?
  version     Int          @default(1)
  results     TestResult[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt

  @@index([projectId])
  @@index([suiteId])
}

// TestResult is the execution record for one case within a run. The snapshot
// columns are copied from the test case at run-creation time and are never
// updated afterwards: history must stay valid even if the case is edited,
// moved, or deleted later.
model TestResult {
  id             Int       @id @default(autoincrement())
  testRunId      Int
  testRun        TestRun   @relation(fields: [testRunId], references: [id], onDelete: Cascade)
  testCaseId     Int
  testCaseName   String?
  title          String?
  preconditions  String?
  steps          String?
  expectedResult String?
  priority       String?
  type           String?
  snapshottedAt  DateTime?
  status         String    @default("Untested")
  comment        String?
  version        Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  @@index([testRunId])
  @@index([testCaseId])
}

model IdempotencyKey {
  id          Int       @id @default(autoincrement())
  key         String
  service     String
  endpoint    String
  requestHash String?
  response    String
  statusCode  Int
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@unique([key, service])
}
